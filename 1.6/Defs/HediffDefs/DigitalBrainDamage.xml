<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>GITM_DigitalBrainDamage</defName>
    <label>digital brain damage</label>
    <description>Data corruption within the subcore caused by physical brain damage in the original organic host. This fragmentation interferes with the mechanoid's processing speed and motor coordination.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.8, 0.4, 0.4)</defaultLabelColor>
    <isBad>true</isBad>
    <initialSeverity>0.1</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <stages>
	<li>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
	<minSeverity>0.1</minSeverity>
        <label>trace corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>minor corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.20</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.3</minSeverity>
        <label>moderate corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.30</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.4</minSeverity>
        <label>significant corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.40</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>serious corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.50</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.6</minSeverity>
        <label>severe corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.60</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.7</minSeverity>
        <label>critical corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.70</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>catastrophic corruption</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.80</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.9</minSeverity>
        <label>total failure</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.90</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>