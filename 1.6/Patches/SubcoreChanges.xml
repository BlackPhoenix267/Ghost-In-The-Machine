<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>

      <li Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="SubcoreRegular"]</xpath>
        <value>
          <stackLimit>1</stackLimit>
        </value>
      </li>
      
      <li Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="SubcoreRegular"]/comps</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="SubcoreRegular"]/comps</xpath>
          <value>
            <li Class="GITM.CompProperties_SubcoreSkillMemory"/>
          </value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="SubcoreRegular"]</xpath>
          <value>
            <comps>
              <li Class="GITM.CompProperties_SubcoreSkillMemory"/>
            </comps>
          </value>
        </nomatch>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="SubcoreHigh"]</xpath>
        <value>
          <stackLimit>1</stackLimit>
        </value>
      </li>
      
      <li Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="SubcoreHigh"]/comps</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="SubcoreHigh"]/comps</xpath>
          <value>
            <li Class="GITM.CompProperties_SubcoreSkillMemory"/>
          </value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="SubcoreHigh"]</xpath>
          <value>
            <comps>
              <li Class="GITM.CompProperties_SubcoreSkillMemory"/>
            </comps>
          </value>
        </nomatch>
      </li>

    </operations>
  </Operation>
</Patch>